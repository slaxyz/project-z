  - sourceNumericId: 1
    id: slugger
    displayName: Slugger
    pseudo: Slugger
    fullName: Alex Reynolds
    description: Alex Reynolds, known as Slugger, was a rising star in baseball celebrated
      for his powerful batting. During a crucial game under a starlit sky, stardust
      infused him with superhuman strength and agility. Now wielding a stardust-charged
      bat, Slugger defends humanity from Underworld threats with resilience and heroism.
    rarityDefinition: {fileID: 11400000, guid: 3e8933f5e086d9c40b20fb0c41335fe6, type: 2}
    typeDefinition: {fileID: 11400000, guid: c23f2a0fad0aade4babadaac15d9314e, type: 2}
